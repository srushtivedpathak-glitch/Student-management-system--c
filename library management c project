#include <stdio.h>
#include <string.h>

struct Book
{
    int id;
    char name[50];
    char author[50];
    int quantity;
};

struct Book b[100];
int count = 0;

// Add Book
void addBook()
{
    printf("\nEnter Book ID: ");
    scanf("%d", &b[count].id);

    printf("Enter Book Name: ");
    scanf(" %[^\n]", b[count].name);

    printf("Enter Author Name: ");
    scanf(" %[^\n]", b[count].author);

    printf("Enter Quantity: ");
    scanf("%d", &b[count].quantity);

    if(b[count].quantity < 0)
    {
        printf("Invalid quantity!\n");
        return;
    }

    count++;
    printf("Book Added Successfully!\n");
}

// Display Books
void displayBooks()
{
    if(count == 0)
    {
        printf("\nNo books available!\n");
        return;
    }

    printf("\n--- Book List ---\n");

    for(int i = 0; i < count; i++)
    {
        printf("\n%d. %s", i+1, b[i].name);
        printf("\n   Author: %s", b[i].author);
        printf("\n   Quantity: %d", b[i].quantity);

        if(b[i].quantity == 0)
            printf("\n   Status: Out of Stock\n");
        else
            printf("\n   Status: Available\n");
    }
}

// Issue Book with quantity check
void issueBook()
{
    int choice, qty;

    if(count == 0)
    {
        printf("\nNo books available!\n");
        return;
    }

    printf("\n--- Select Book to Issue ---\n");

    for(int i = 0; i < count; i++)
    {
        printf("%d. %s (Available: %d)\n", i+1, b[i].name, b[i].quantity);
    }

    printf("Enter book number: ");
    scanf("%d", &choice);

    if(choice < 1 || choice > count)
    {
        printf("Invalid choice!\n");
        return;
    }

    printf("How many books do you want to issue? ");
    scanf("%d", &qty);

    if(qty <= 0)
    {
        printf("Invalid quantity!\n");
        return;
    }

    if(b[choice-1].quantity >= qty)
    {
        b[choice-1].quantity -= qty;
        printf("%d Book(s) Issued Successfully!\n", qty);
    }
    else
    {
        printf("Only %d book(s) available!\n", b[choice-1].quantity);
    }
}

// Return Book with quantity
void returnBook()
{
    int choice, qty;

    if(count == 0)
    {
        printf("\nNo books available!\n");
        return;
    }

    printf("\n--- Select Book to Return ---\n");

    for(int i = 0; i < count; i++)
    {
        printf("%d. %s\n", i+1, b[i].name);
    }

    printf("Enter book number: ");
    scanf("%d", &choice);

    if(choice < 1 || choice > count)
    {
        printf("Invalid choice!\n");
        return;
    }

    printf("How many books to return? ");
    scanf("%d", &qty);

    if(qty <= 0)
    {
        printf("Invalid quantity!\n");
        return;
    }

    b[choice-1].quantity += qty;
    printf("%d Book(s) Returned Successfully!\n", qty);
}

// Main Function
int main()
{
    int choice;

    do
    {
        printf("\n\n===== LIBRARY MANAGEMENT SYSTEM =====");
        printf("\n1. Add Book");
        printf("\n2. Display Books");
        printf("\n3. Issue Book");
        printf("\n4. Return Book");
        printf("\n5. Exit");
        printf("\nEnter Choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1: addBook(); break;
            case 2: displayBooks(); break;
            case 3: issueBook(); break;
            case 4: returnBook(); break;
            case 5: printf("Exiting...\n"); break;
            default: printf("Invalid Choice!\n");
        }

    } while(choice != 5);

    return 0;
}
